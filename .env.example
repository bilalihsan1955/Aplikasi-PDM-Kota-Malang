# Salin file ini ke .env dan isi nilai sesuai environment Anda
API_BASE_URL=https://your-domain.com/api/v1

# Origin situs web (WebView HTML), jika beda dari host API. Contoh: https://makotamu.org
# Kosongkan agar di-duga dari API_BASE_URL (hapus sufiks /api/v1 bila ada).
# WEB_BASE_URL=https://makotamu.org

# Base URL API Waktu Sholat (https://github.com/maftuh23/waktu-sholat). Opsional; default: https://waktu-sholat.vercel.app
# Set jika Anda deploy sendiri (mis. Vercel) agar lokasi & jadwal by lat/long dipakai.
# WAKTU_SHOLAT_API_URL=https://your-waktu-sholat.vercel.app
