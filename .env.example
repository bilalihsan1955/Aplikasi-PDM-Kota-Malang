# Salin file ini ke .env dan isi nilai sesuai environment Anda
API_BASE_URL=https://your-domain.com/api/v1

# Origin situs web (WebView HTML), jika beda dari host API. Contoh: https://makotamu.org
# Kosongkan agar di-duga dari API_BASE_URL (hapus sufiks /api/v1 bila ada).
# WEB_BASE_URL=https://makotamu.org

# --- Jadwal sholat & kiblat (dotenv) ---
# API utama waktu-sholat (lokasi + /prayer). Default: https://waktu-sholat.vercel.app
# WAKTU_SHOLAT_API_URL=https://your-waktu-sholat.vercel.app

# API arah kiblat (path /qibla/{lat}/{lng}). Default: https://api.aladhan.com/v1
# QIBLA_API_BASE_URL=https://api.aladhan.com/v1

# Fallback jadwal MyQuran. Default: https://api.myquran.com/v2
# MYQURAN_API_BASE_URL=https://api.myquran.com/v2

# Nominatim reverse geocode. Default: https://nominatim.openstreetmap.org
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
